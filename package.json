{
  "name": "@anhnguyen0905/codex-mcp",
  "version": "0.3.2",
  "description": "MCP server bridging Claude Code and OpenAI Codex CLI for plan-execute-review workflows",
  "main": "dist/index.js",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/anhnguyen0905/codex-mcp.git"
  },
  "homepage": "https://github.com/anhnguyen0905/codex-mcp#readme",
  "bugs": {
    "url": "https://github.com/anhnguyen0905/codex-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "directories": {
    "test": "tests"
  },
  "scripts": {
    "test": "vitest run",
    "build": "tsc",
    "coverage": "vitest run --coverage",
    "test:e2e": "node scripts/smoke-e2e.mjs",
    "doctor": "node scripts/doctor.mjs",
    "prepare": "npm run build",
    "start": "node dist/index.js"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "codex",
    "claude-code",
    "openai-codex",
    "ai-agents",
    "code-review"
  ],
  "author": "anhnguyen0905",
  "license": "MIT",
  "type": "module",
  "bin": {
    "codex-mcp": "dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@vitest/coverage-v8": "^4.1.10",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "scripts/tail-progress.mjs",
    "scripts/doctor.mjs",
    "README.md",
    "LICENSE"
  ]
}
