    { "id": "S24", "scope": "reinforcement-learning", "facet": "data", "request": "Train an RL agent with stable baselines", "terms": ["reinforcement learning", "stable baselines", "agent", "rl"], "expectAny": ["stable-baselines3", "pufferlib"] },
    { "id": "S25", "scope": "chemistry", "facet": "data", "request": "Compute molecular descriptors with RDKit", "terms": ["rdkit", "molecular", "cheminformatics", "descriptors"], "expectAny": ["rdkit", "molfeat", "medchem"] },
    { "id": "S26", "scope": "quantum", "facet": "data", "request": "Build a quantum circuit with Qiskit", "terms": ["qiskit", "quantum", "circuit", "qubit"], "expectAny": ["qiskit", "cirq", "pennylane"] },
    { "id": "S27", "scope": "game-design", "facet": "product", "request": "Balance hero stats and gacha drop rates for a mobile game", "terms": ["game", "balance", "economy", "gacha", "stats"], "expectAny": ["game-designer-balance"] },
    { "id": "S28", "scope": "game-design", "facet": "product", "request": "Design how game systems connect and depend on each other", "terms": ["game", "systems", "dependency", "mechanic"], "expectAny": ["game-designer-systems"] },
