    { "id": "S30", "scope": "browser-automation", "facet": "engineering", "request": "Automate a browser flow and test a local web app", "terms": ["playwright", "browser", "automation", "webapp"], "expectAny": ["playwright-skill", "webapp-testing"] },
    { "id": "S31", "scope": "multi-facet", "facet": "data+marketing", "request": "Build a data dashboard and write the launch announcement post", "terms": ["dashboard", "visualisation", "chart", "market research", "launch", "positioning"], "expectAny": ["d3-viz", "claude-d3js-skill", "market-research-reports"] },
    { "id": "S32", "scope": "uncovered", "facet": "engineering", "request": "Modernize a legacy COBOL mainframe batch job", "terms": ["cobol", "mainframe", "jcl", "batch"], "expectEmpty": true }
