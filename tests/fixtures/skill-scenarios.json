{
  "note": "30 scope scenarios for skill-selection retrieval eval. `terms` = search terms Claude derives per role facet (Step 2). `expectAny` = at least one must appear in the top-3 selection. `expectNone` = must NOT appear. `expectEmpty` = uncovered domain, selection must be empty.",
  "scenarios": [
    { "id": "S01", "scope": "engineering", "facet": "engineering", "request": "Implement a REST endpoint in a TypeScript Node service", "terms": ["typescript", "javascript", "node", "async"], "expectAny": ["exec-typescript"] },
    { "id": "S02", "scope": "engineering", "facet": "engineering", "request": "Add a concurrent worker pool to a Go service", "terms": ["go", "golang", "concurrency", "goroutine"], "expectAny": ["exec-go"] },
    { "id": "S03", "scope": "engineering", "facet": "engineering", "request": "Package a Python library with type hints and PEP 8 compliance", "terms": ["python", "packaging", "type hints", "pep 8"], "expectAny": ["exec-python", "modern-python"] },
    { "id": "S04", "scope": "data-viz", "facet": "data", "request": "Build an interactive d3.js chart with custom transitions", "terms": ["d3", "visualisation", "chart", "svg", "interactive"], "expectAny": ["d3-viz", "claude-d3js-skill"] },
    { "id": "S05", "scope": "data-analysis", "facet": "data", "request": "Analyze a large CSV with fast DataFrame operations", "terms": ["dataframe", "data analysis", "polars", "pandas"], "expectAny": ["polars", "vaex", "dask"] },
    { "id": "S06", "scope": "data-analysis", "facet": "data", "request": "Run statistical regression and hypothesis tests on a dataset", "terms": ["statistical", "regression", "statistics", "statsmodels"], "expectAny": ["statsmodels", "statistical-analysis", "scikit-learn"] },
    { "id": "S07", "scope": "data-analysis", "facet": "data", "request": "Do exploratory data analysis on a new dataset", "terms": ["exploratory", "data analysis", "eda"], "expectAny": ["exploratory-data-analysis"] },
    { "id": "S08", "scope": "marketing", "facet": "marketing", "request": "Produce a market research and competitor positioning report", "terms": ["market research", "competitor", "positioning", "report"], "expectAny": ["market-research-reports"], "expectNone": ["exec-python", "pdf"] },
    { "id": "S09", "scope": "product", "facet": "product", "request": "Draft a product roadmap and backlog for a new feature", "terms": ["product", "roadmap", "backlog", "manager"], "expectAny": ["product-manager", "project-manager"] },
    { "id": "S10", "scope": "design", "facet": "design", "request": "Design a bold non-generic frontend for a React/Tailwind app", "terms": ["frontend", "design", "aesthetic", "tailwind"], "expectAny": ["frontend-design"] },
    { "id": "S11", "scope": "design", "facet": "design", "request": "Create an animation-rich HTML slide presentation", "terms": ["slides", "presentation", "html", "animation"], "expectAny": ["frontend-slides", "scientific-slides"] },
    { "id": "S12", "scope": "security", "facet": "security", "request": "Set up coverage-guided fuzzing for a C library", "terms": ["fuzzing", "libfuzzer", "coverage", "afl"], "expectAny": ["libfuzzer", "aflpp", "libafl", "cargo-fuzz"] },
    { "id": "S13", "scope": "security", "facet": "security", "request": "Write custom Semgrep rules for static analysis", "terms": ["semgrep", "static analysis", "rule"], "expectAny": ["semgrep-rule-creator", "semgrep", "semgrep-rule-variant-creator"] },
    { "id": "S14", "scope": "security", "facet": "security", "request": "Audit a Solana smart contract for vulnerabilities", "terms": ["solana", "vulnerability", "smart contract", "scanner"], "expectAny": ["solana-vulnerability-scanner"] },
    { "id": "S15", "scope": "bioinformatics", "facet": "data", "request": "Run a bulk RNA-seq differential expression analysis", "terms": ["rnaseq", "differential expression", "bulk", "deseq"], "expectAny": ["bulk-rnaseq", "pydeseq2"] },
    { "id": "S16", "scope": "bioinformatics", "facet": "data", "request": "Cluster single-cell RNA data with scanpy", "terms": ["scanpy", "single cell", "clustering", "anndata"], "expectAny": ["scanpy", "scvi-tools", "anndata"] },
    { "id": "S17", "scope": "document", "facet": "document", "request": "Extract tables and text from a batch of PDF files", "terms": ["pdf", "extract", "tables", "document"], "expectAny": ["pdf"] },
    { "id": "S18", "scope": "document", "facet": "document", "request": "Generate a formatted Word document and an Excel spreadsheet", "terms": ["docx", "word", "xlsx", "excel", "spreadsheet"], "expectAny": ["docx", "xlsx"] },
    { "id": "S19", "scope": "testing", "facet": "engineering", "request": "Follow TDD to build a new feature test-first", "terms": ["tdd", "test driven", "test-first", "testing"], "expectAny": ["test-driven-development"] },
    { "id": "S20", "scope": "testing", "facet": "engineering", "request": "Add property-based tests to a parser", "terms": ["property based", "property-based", "hypothesis", "testing"], "expectAny": ["property-based-testing"] },
